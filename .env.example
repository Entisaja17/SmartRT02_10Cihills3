# Contoh file konfigurasi untuk production deployment
# Copy ke koneksi.php di hosting dan isi dengan credentials hosting Anda

# ================================
# DATABASE CREDENTIALS
# ================================
# Ganti nilai di bawah dengan credentials hosting Anda

# Hostname database (biasanya 'localhost')
DB_HOST=localhost

# Nama database yang sudah dibuat di cPanel
DB_NAME=db_smart_rt

# Username MySQL yang sudah dibuat di cPanel
DB_USER=your_db_user

# Password database (buat password kuat!)
DB_PASS=your_db_password

# Port MySQL (default 3306)
DB_PORT=3306

# Character set
DB_CHARSET=utf8mb4

# ================================
# API CONFIGURATION
# ================================

# Base URL untuk CORS (ganti dengan domain Anda)
API_BASE_URL=https://yourdomain.com/api

# Enable detailed error logging (set to 0 di production!)
DEBUG_MODE=0

# ================================
# TIPS FILLING THIS FILE
# ================================
# 1. Login ke cPanel hosting Anda
# 2. Buka MySQL Databases
# 3. Lihat "Current Databases" dan "MySQL Users"
# 4. Copy credentials ke sini
# 5. Update file koneksi.php dengan nilai-nilai ini
